# AI Interview Question Generator - Backend Environment Configuration

# OpenAI API Settings
# To enable AI-powered generation, register for an API key at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Supabase Database & Auth Settings
# Leave these empty to automatically fall back to local SQLite database and mock authentication.
# To connect to a live Supabase project, enter your credentials below.
SUPABASE_URL=
SUPABASE_KEY=

# Local Development JWT Secret (for SQLite authentication mode)
LOCAL_JWT_SECRET=super-secret-local-development-key-change-this-in-production
